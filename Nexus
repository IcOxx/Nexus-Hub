local Players = game:GetService("Players")

local function kickWithMessage(player)
    -- 1. Création d'un message d'alerte natif Roblox (très difficile à ignorer)
    local msg = Instance.new("Message")
    msg.Text = "\n\n⚠️ SCRIPT IS PAID. ⚠️\n\nPlease contact the owner for access."
    msg.Parent = player:WaitForChild("PlayerGui")
    
    -- 2. On laisse le temps au joueur de VOIR le message
    task.wait(2) 
    
    -- 3. On kick avec le même message en sécurité
    player:Kick("SCRIPT IS PAID.")
end

-- Gestion du démarrage (Pour toi en Studio)
for _, player in ipairs(Players:GetPlayers()) do
    task.spawn(kickWithMessage, player)
end

-- Gestion des nouveaux arrivants
Players.PlayerAdded:Connect(kickWithMessage)
